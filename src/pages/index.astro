---
import '@fontsource/anton';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Social from '@/components/Social.astro';
---

<BaseLayout>
  <div class="pt-10 pb-6 px-3">
    <h1 class="flex flex-col text-3xl text-black leading-normal tracking-wider font-[Anton]">
      <span>Hello,</span><span>I'm Paranoid_K</span>
    </h1>
    <div class="mt-6 text-gray-900 space-y-1.5">
      <p>🧑‍💻 前端开发者 / Front-end Developer</p>
      <p>🤩 正在做一些有趣的事 / Working on something interesting</p>
      <p>
        🥰
        <a href="https://sotake.com" target="_blank" class="hover:underline">sotake.com</a>
        <span>·</span>
        <a href="https://kee.so" target="_blank" class="hover:underline">kee.so</a>
      </p>
    </div>
    <Social />
  </div>
</BaseLayout>
