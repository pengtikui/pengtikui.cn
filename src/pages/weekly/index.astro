---
import BaseLayout from '@/layouts/BaseLayout.astro';
import List from '@/components/List.astro';
import { getCollectionList } from '@/libs/collection';

const weeklies = await getCollectionList('weekly');
---

<BaseLayout>
  <Fragment slot="head">
    <title>Paranoid_K's Weekly</title>
  </Fragment>
  <div class="pt-10 pb-6 px-3">
    <h1 class="flex text-3xl text-black leading-normal tracking-wider font-bold font-[Lato]">
      周刊<span class="mx-1">·</span>Weekly
    </h1>
    <p class="mt-4 text-gray-600 text-sm leading-relaxed">
      我会在这分享近期看到的、学到的新奇好玩的东西或技术，内容包括但不仅限于前端技术、设计和 TMT 行业资讯等。
    </p>
  </div>
  <List list={weeklies} />
</BaseLayout>
