{
  "name": "next-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.0.15",
    "@fontsource/anton": "^5.0.17",
    "astro": "^3.6.0"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^5.0.2",
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "18.16.3",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "prettier": "^3.1.0",
    "prettier-plugin-astro": "^0.12.2",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.3.2"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-astro"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ],
    "printWidth": 120,
    "singleQuote": true
  }
}
